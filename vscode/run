#!/bin/sh

set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

docker run --rm --init \
  --name="$(basename $1)" \
  --cap-drop=ALL \
  --security-opt seccomp="$SCRIPT_DIR/../seccomp-electron.json" \
  --shm-size="1gb" \
  --tmpfs /tmp:exec \
  --tmpfs /home/colin/.cache:exec \
  -v "$1":/home/colin/project \
  -p 127.0.0.1:5900:5900 \
  vscode
