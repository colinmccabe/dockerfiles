#!/bin/sh
set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
PROJ_DIR=$1

docker run --rm -it \
  --cap-drop=ALL --security-opt=no-new-privileges \
  -u 1000:1000 \
  -v "$SCRIPT_DIR/claude.json":/home/node/.claude.json \
  -v "$PROJ_DIR/.claude":/home/node/.claude \
  -v "$PROJ_DIR":/home/node/workdir \
  claude-code \
  -- \
  "$@"
