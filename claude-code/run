#!/bin/bash
set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
PROJ_NAME=$(basename "$(pwd)")

if [ ! -d .claude ]; then
  mkdir -p .claude
  setfacl -m u:100999:rwx,d:u:colin:rwX .claude
fi

if [ ! -f .claude.json ]; then
  echo '{}' > .claude.json
  setfacl -m u:100999:rwx .claude.json
fi

docker run --rm -it \
  --name "claude-code--$PROJ_NAME" \
  --cap-drop=ALL --security-opt=no-new-privileges \
  --read-only \
  -u 1000:1000 \
  --tmpfs /tmp \
  -v "$SCRIPT_DIR/api-key":/home/node/api-key:ro \
  -v "$(pwd)"/.claude:/home/node/.claude \
  -v "$SCRIPT_DIR/settings.json":/home/node/.claude/settings.json:ro \
  -v "$(pwd)"/.claude.json:/home/node/.claude.json \
  -v "$(pwd)":/home/node/workdir \
  claude-code \
  -- \
  "$@"
