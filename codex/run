#!/bin/sh
set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

if [ ! -d .codex ]; then
  mkdir -p .codex
  setfacl -m u:100999:rwx,d:u:colin:rwX,d:u:100999:rwX .codex
fi

docker run --rm -it \
  --cap-drop=ALL --security-opt=no-new-privileges \
  --read-only \
  -u 1000:1000 \
  --tmpfs /tmp \
  -v "$(pwd)"/.codex:/home/node/.codex \
  -v "$SCRIPT_DIR/auth.json":/home/node/.codex/auth.json \
  -v "$(pwd)":/home/node/workdir \
  codex \
  "$@"
