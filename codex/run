#!/bin/sh
set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
PROJ_DIR=$1; shift

docker run --rm -it \
  --cap-drop=ALL --security-opt=no-new-privileges \
  --read-only \
  -u 1000:1000 \
  --tmpfs /tmp \
  -v "$PROJ_DIR/.codex":/home/node/.codex \
  -v "$PROJ_DIR":/home/node/workdir \
  codex \
  -- \
  "$@"
