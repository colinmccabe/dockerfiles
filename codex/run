#!/bin/sh
set -eu

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
echo "$SCRIPT_DIR/auth.json"

docker run --rm -it \
  --cap-drop=ALL --security-opt=no-new-privileges \
  --read-only \
  -u 1000:1000 \
  --tmpfs /tmp \
  -v "$(pwd)"/.codex:/home/node/.codex \
  -v "$SCRIPT_DIR/auth.json":/home/node/.codex/auth.json:ro \
  -v "$(pwd)":/home/node/workdir \
  codex \
  -- \
  "$@"
